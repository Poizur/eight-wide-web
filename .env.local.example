# ══════════════════════════════════════════
# Eight Wide — Environment Variables
# Zkopiruj jako .env.local a vyplň skutečné hodnoty
# ══════════════════════════════════════════

# ── Supabase (povinné) ──
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Base URL (povinné) ──
NEXT_PUBLIC_BASE_URL=https://speedchampions.cz

# ── Cron secret (povinné pro Vercel cron jobs) ──
CRON_SECRET=...nahodny_string_32_znaku...

# ── Resend — email/newsletter (volitelné, potřeba pro Fázi 5) ──
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=newsletter@speedchampions.cz
# RESEND_FROM_NAME=Eight Wide

# ── Brickset API — import setů (volitelné) ──
# BRICKSET_API_KEY=...
# BRICKSET_USERNAME=...
# BRICKSET_PASSWORD=...

# ── Unsplash — fotky reálných aut (volitelné) ──
# UNSPLASH_ACCESS_KEY=...

# ── BrickLink API — sekundární trh (volitelné) ──
# BRICKLINK_CONSUMER_KEY=...
# BRICKLINK_CONSUMER_SECRET=...
# BRICKLINK_TOKEN=...
# BRICKLINK_TOKEN_SECRET=...

# ── Anthropic — AI agent (separátní repo) ──
# ANTHROPIC_API_KEY=sk-ant-...
